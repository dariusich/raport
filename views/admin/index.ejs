<%- include('../partials/header') %>
<section class="hero">
  <div><p class="eyebrow">admin</p><h1>Dashboard manageri</h1><p class="muted">Gestionezi trainerii, rapoartele și plata pe seminarii.</p></div>
  <div class="stats"><div><b><%= totalSeminars %></b><span>seminarii</span></div><div><b><%= activeReports %></b><span>active</span></div><div><b><%= finalizedReports %></b><span>finalizate</span></div></div>
</section>

<section class="grid two">
  <div class="card" id="trainers"><h2>Adaugă trainer</h2>
    <form method="post" action="/admin/trainers" class="stack">
      <div class="grid two compact"><label>Nume<input name="name" required></label><label>User<input name="username" required></label></div>
      <div class="grid two compact"><label>Parolă<input name="password" required></label><label>Filială<input name="location"></label></div>
      <label>Comision/seminar <input name="commissionPerSeminar" type="number" step="0.01" value="0"></label>
      <button class="primary">Creează trainer</button>
    </form>
  </div>
  <div class="card" id="reports"><h2>Creează raport</h2>
    <form method="post" action="/admin/reports" class="stack">
      <label>Trainer<select name="trainerId" required><% trainers.forEach(t => { %><option value="<%= t._id %>"><%= t.name %> · <%= t.location || 'fără filială' %></option><% }) %></select></label>
      <label>Titlu raport<input name="title" placeholder="ex: Maseur calificare seria 20.10.2025 - 10.05.2026" required></label>
      <div class="grid two compact"><label>Data început<input type="date" name="startDate"></label><label>Data final<input type="date" name="endDate"></label></div>
      <label>Filială<input name="location"></label>
      <label>Lista cursanți, un nume pe rând<textarea name="traineesText" rows="7" placeholder="Popescu Ana&#10;Ionescu Mihai"></textarea></label>
      <label>Note admin<textarea name="adminNotes" rows="2"></textarea></label>
      <button class="primary">Alocă raport</button>
    </form>
  </div>
</section>

<section class="card"><h2>Traineri</h2><div class="table-wrap"><table><thead><tr><th>Nume</th><th>User</th><th>Filială</th><th>Comision</th><th>Status</th><th>Acțiuni</th></tr></thead><tbody><% trainers.forEach(t => { %><tr><td><%= t.name %></td><td><%= t.username %></td><td><%= t.location %></td><td><%= t.commissionPerSeminar %></td><td><span class="pill <%= t.active ? 'ok' : 'off' %>"><%= t.active ? 'activ' : 'inactiv' %></span></td><td class="actions"><form method="post" action="/admin/trainers/<%= t._id %>/toggle"><button class="ghost"><%= t.active ? 'Dezactivează' : 'Activează' %></button></form><form method="post" action="/admin/trainers/<%= t._id %>/password"><input name="password" placeholder="parolă nouă"><button class="ghost">Schimbă</button></form></td></tr><% }) %></tbody></table></div></section>

<section class="card"><div class="row"><h2>Rapoarte</h2><input class="search" data-table-search placeholder="Caută trainer, raport, filială..."></div><div class="table-wrap"><table data-searchable><thead><tr><th>Raport</th><th>Trainer</th><th>Filială</th><th>Status</th><th>Seminarii</th><th>Actualizat</th><th></th></tr></thead><tbody><% reports.forEach(r => { %><tr><td><%= r.title %></td><td><%= r.trainer?.name || '-' %></td><td><%= r.location %></td><td><span class="pill <%= r.status === 'finalized' ? 'ok' : 'warn' %>"><%= r.status === 'finalized' ? 'finalizat' : 'activ' %></span></td><td><%= r.seminars.length %></td><td><%= r.updatedAt.toLocaleDateString('ro-RO') %></td><td><a class="ghost inline" href="/admin/reports/<%= r._id %>">Detalii</a></td></tr><% }) %></tbody></table></div></section>
<%- include('../partials/footer') %>
