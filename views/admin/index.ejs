<%- include('../partials/header') %>

<%
  const accountingCourses = [...new Set(accounting.flatMap(item => item.courses.map(course => course.name)))].sort((a, b) => a.localeCompare(b, 'ro'));
%>

<section class="hero hero-admin">
  <div>
    <p class="eyebrow">Dashboard manageri</p>
    <h1>Reflexovital · Academia de Cursuri</h1>
    <p class="hero-text">Administrezi rapoarte, traineri și evidența pentru contabilitate în taburi separate, mai curate și mai rapide.</p>
  </div>
  <div class="hero-stats">
    <div><strong><%= totalSeminars %></strong><span>seminarii</span></div>
    <div><strong><%= activeReports %></strong><span>active</span></div>
    <div><strong><%= finalizedReports %></strong><span>finalizate</span></div>
  </div>
</section>

<section class="dashboard-activity">
  <div class="activity-intro">
    <span class="activity-icon">!</span>
    <div>
      <p class="eyebrow">Noutăți rapoarte</p>
      <h2>Activitate recentă în rapoarte</h2>
      <p>Urmărește cele mai recente actualizări făcute de traineri și administratori.</p>
    </div>
  </div>
  <div class="activity-items">
    <% if (recentActivity.length) { %>
      <% recentActivity.forEach(item => { %>
        <a class="activity-item" href="<%= item.href %>">
          <span class="activity-avatar"><%= item.icon %></span>
          <span>
            <strong><%= item.title %></strong>
            <small><%= item.time %></small>
          </span>
        </a>
      <% }) %>
    <% } else { %>
      <div class="activity-item empty">
        <span class="activity-avatar">0</span>
        <span>
          <strong>Nu există activitate recentă</strong>
          <small>Primele modificări vor apărea aici automat.</small>
        </span>
      </div>
    <% } %>
  </div>
  <a class="btn small ghost activity-link" href="/admin#istoric">Vezi toate modificările</a>
</section>

<section class="admin-home" data-admin-home>
  <div class="admin-home-copy">
    <h2>Alege zona de lucru</h2>
  </div>
  <% if (seriesRequests.length) { %>
    <section class="series-requests-admin" id="solicitari-serii">
      <details class="series-requests-accordion">
        <summary>
          <div>
            <span class="pill red">Solicitări serii</span>
            <h2><%= openSeriesRequests %> solicitări noi</h2>
            <p>Trainerii care nu își văd seria pot trimite aici detaliile cursului lipsă.</p>
          </div>
        </summary>
        <div class="series-request-admin-list">
          <% seriesRequests.forEach(request => { %>
            <article class="series-request-admin-row <%= request.status %>">
              <div>
                <span class="status <%= request.status === 'open' ? 'active' : 'finalized' %>">
                  <%= request.status === 'open' ? 'nouă' : request.status === 'resolved' ? 'rezolvată' : 'respinsă' %>
                </span>
                <h3><%= request.courseName %></h3>
                <p>
                  <%= request.trainer?.name || 'Trainer' %>
                  <% if (request.location) { %> · <%= request.location %><% } %>
                  <% if (request.startDate) { %> · <%= new Date(request.startDate).toLocaleDateString('ro-RO') %><% } %>
                  <% if (request.endDate) { %> - <%= new Date(request.endDate).toLocaleDateString('ro-RO') %><% } %>
                </p>
                <% if (request.notes) { %><small><%= request.notes %></small><% } %>
              </div>
              <div class="table-actions">
                <% if (request.status === 'open') { %>
                  <form action="/admin/series-requests/<%= request._id %>/status" method="post">
                    <input type="hidden" name="status" value="resolved">
                    <button class="btn small success" type="submit">Marchează rezolvată</button>
                  </form>
                  <form action="/admin/series-requests/<%= request._id %>/status" method="post">
                    <input type="hidden" name="status" value="rejected">
                    <button class="btn small ghost" type="submit">Respinge</button>
                  </form>
                <% } %>
                <form action="/admin/series-requests/<%= request._id %>/delete" method="post" onsubmit="return confirm('Ștergi definitiv această solicitare?');">
                  <button class="btn small danger" type="submit">Șterge definitiv</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      </details>
    </section>
  <% } %>
  <div class="admin-home-grid" aria-label="Sectiuni admin">
    <button class="admin-home-card" data-tab-target="rapoarte" type="button">
      <span>01</span>
      <strong>Rapoarte</strong>
      <small>Genereaza serii, aloca traineri si verifica rapoartele create.</small>
    </button>
    <button class="admin-home-card" data-tab-target="traineri" type="button">
      <span>02</span>
      <strong>Traineri</strong>
      <small>Administreaza conturi, statusuri si parole.</small>
    </button>
    <button class="admin-home-card" data-tab-target="contabilitate" type="button">
      <span>03</span>
      <strong>Contabilitate</strong>
      <small>Filtreaza seminarii, calculeaza plata si exporta Excel.</small>
    </button>
  </div>
</section>

<section class="tab-panel" id="istoric">
  <section class="card">
    <div class="section-title row-title">
      <div>
        <span class="pill red">Istoric</span>
        <h2>Toate modificările</h2>
        <p>Vezi ultimele acțiuni din platformă și șterge intrările care nu mai sunt utile.</p>
      </div>
    </div>
    <div class="history-list">
      <% if (activityLogs.length) { %>
        <% activityLogs.forEach(item => { %>
          <article class="history-row">
            <div class="history-main">
              <span class="activity-avatar"><%= item.icon %></span>
              <div>
                <strong><%= item.title %></strong>
                <small><%= item.actorName || 'Sistem' %><%= item.actorRole ? ' · ' + item.actorRole : '' %> · <%= item.dateLabel || item.time %></small>
              </div>
            </div>
            <div class="table-actions">
              <% if (item.href) { %>
                <a class="btn small ghost" href="<%= item.href %>">Vezi</a>
              <% } %>
              <form action="/admin/activity/<%= item.id %>/delete" method="post" onsubmit="return confirm('Ștergi această intrare din istoric?');">
                <button class="btn small danger" type="submit">Șterge</button>
              </form>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <div class="history-empty">
          <strong>Istoricul este gol</strong>
          <small>Acțiunile noi vor apărea aici automat.</small>
        </div>
      <% } %>
    </div>
  </section>
</section>

<section class="tab-panel" id="rapoarte">
  <div class="subtabs">
    <button class="tab-button active" data-subtab-target="rapoarte-generate" type="button">Rapoarte generate</button>
    <button class="tab-button" data-subtab-target="genereaza-raport" type="button">Generează raport</button>
    <button class="tab-button" data-subtab-target="import-raport-vechi" type="button">Import raport vechi</button>
  </div>

  <div class="subpanel" id="genereaza-raport">
    <div class="card">
      <div class="section-title">
        <span class="pill gold">Rapoarte</span>
        <h2>Creează și alocă raport</h2>
        <p>Încarcă tabelul nominal Word ca să se precompleteze automat cursul, perioada și lista de cursanți.</p>
      </div>
      <form action="/admin/reports" method="post" enctype="multipart/form-data" class="form-grid">
        <label>Trainer
          <select name="trainerId" required>
            <% trainers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Tabel nominal Word (.docx)
          <input name="nominalDoc" type="file" accept=".docx">
          <small>Opțional. Sistemul încearcă să citească automat numele cursului, seria/perioada și cursanții.</small>
        </label>
        <label>Titlu raport <input name="title" placeholder="Se completează automat din Word sau manual"></label>
        <div class="inline-2">
          <label>Data început <input name="startDate" type="date"></label>
          <label>Data final <input name="endDate" type="date"></label>
        </div>
        <label>Filială serie <input name="location" required placeholder="ex: Sibiu, Iași, Bacău"></label>
        <label>Lista cursanți manual, un nume pe rând
          <textarea name="traineesText" rows="5" placeholder="Folosește doar dacă nu încarci Word sau dacă vrei să completezi manual lista."></textarea>
        </label>
        <label>Note admin <textarea name="adminNotes" rows="3" placeholder="Detalii interne despre serie, program, observații."></textarea></label>
        <button class="btn primary full" type="submit">Alocă raport trainerului</button>
      </form>
    </div>
  </div>

  <div class="subpanel" id="import-raport-vechi">
    <div class="card">
      <div class="section-title">
        <span class="pill gold">Import Excel</span>
        <h2>Import raport vechi</h2>
        <p>Incarca Excelul vechi, alege trainerul, apoi verifica previzualizarea inainte de crearea raportului nou.</p>
      </div>
      <form action="/admin/legacy-import/preview" method="post" enctype="multipart/form-data" class="form-grid">
        <label>Trainer
          <select name="trainerId" required>
            <% trainers.forEach(t => { %>
              <option value="<%= t._id %>"><%= t.name %></option>
            <% }) %>
          </select>
        </label>
        <label>Raport vechi Excel (.xlsx)
          <input name="legacyExcel" type="file" accept=".xlsx" required>
          <small>Sistemul citeste foile lunare, cursantii si seminariile completate.</small>
        </label>
        <button class="btn primary full" type="submit">Analizeaza Excel</button>
      </form>
    </div>
  </div>

  <div class="subpanel active" id="rapoarte-generate">
    <section class="card">
      <div class="section-title row-title">
        <div>
          <span class="pill gold">Rapoarte generate</span>
          <h2>Rapoarte create</h2>
          <p>Vezi rapid statusul, trainerul și numărul de seminarii completate.</p>
        </div>
      </div>
      <div class="report-table-filters" data-report-filters>
        <input id="adminReportSearch" type="search" placeholder="Caută după raport, trainer sau filială...">
        <select id="adminReportStatusFilter">
          <option value="all">Toate statusurile</option>
          <option value="active">Active</option>
          <option value="finalized">Finalizate</option>
        </select>
        <select id="adminReportSort">
          <option value="updated-desc">Actualizate recent</option>
          <option value="title-asc">Titlu A-Z</option>
          <option value="trainer-asc">Trainer A-Z</option>
          <option value="seminars-desc">Cele mai multe seminarii</option>
        </select>
      </div>
      <div class="table-wrap">
        <table id="adminReportsTable">
          <thead><tr><th>Raport</th><th>Trainer</th><th>Filială</th><th>Status</th><th>Seminarii</th><th>Actualizat</th><th>Acțiuni</th></tr></thead>
          <tbody>
            <% reports.forEach(r => { %>
              <tr
                data-report-row
                data-title="<%= String(r.title || '').toLowerCase() %>"
                data-trainer="<%= String(r.trainer?.name || '').toLowerCase() %>"
                data-location="<%= String(r.location || '').toLowerCase() %>"
                data-status="<%= r.status %>"
                data-seminars="<%= r.seminars.length %>"
                data-updated="<%= r.updatedAt ? new Date(r.updatedAt).getTime() : 0 %>"
              >
                <td><strong><%= r.title %></strong></td>
                <td><%= r.trainer?.name || '-' %></td>
                <td><%= r.location %></td>
                <td><span class="status <%= r.status %>"><%= r.status === 'finalized' ? 'finalizat' : 'activ' %></span></td>
                <td><%= r.seminars.length %></td>
                <td><%= r.updatedAt.toLocaleDateString('ro-RO') %></td>
                <td>
                  <div class="table-actions">
                    <a class="btn small primary" href="/admin/reports/<%= r._id %>">Detalii</a>
                    <% if (r.status !== 'finalized') { %>
                      <form action="/admin/reports/<%= r._id %>/finalize" method="post">
                        <input type="hidden" name="returnTo" value="/admin#rapoarte-generate">
                        <button class="btn small success" type="submit">Marchează ca finalizat</button>
                      </form>
                    <% } %>
                    <form action="/admin/reports/<%= r._id %>/delete" method="post" onsubmit="return confirm('Sigur vrei să ștergi seria «<%= String(r.title || '').replace(/'/g, '&#39;') %>»? Se vor șterge și seminariile completate.');">
                      <input type="hidden" name="returnTo" value="/admin#rapoarte-generate">
                      <button class="btn small danger" type="submit">Șterge serie</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</section>

<section class="tab-panel" id="traineri">
  <section class="grid-2">
    <div class="card">
      <div class="section-title">
        <span class="pill">Traineri</span>
        <h2>Adaugă trainer</h2>
        <p>Comisionul nu mai este aici. Plata se calculează separat în Contabilitate.</p>
      </div>
      <form action="/admin/trainers" method="post" class="form-grid">
        <label>Nume<input name="name" required placeholder="Nume trainer"></label>
        <label>User<input name="username" required placeholder="ex: maria.pop"></label>
        <label>Parolă<input name="password" type="password" required placeholder="Parolă inițială"></label>
        <button class="btn primary full" type="submit">Creează trainer</button>
      </form>
    </div>

    <div class="card">
      <div class="section-title"><span class="pill">Listă</span><h2>Traineri existenți</h2></div>
      <div class="trainer-accordion">
        <% trainers.forEach(t => { %>
          <article class="trainer-accordion-item">
            <button class="trainer-accordion-head" type="button" data-trainer-toggle="<%= t._id %>">
              <span>
                <strong><%= t.name %></strong>
                <small>user: <%= t.username %></small>
              </span>
              <span class="status <%= t.active ? 'active' : 'inactive' %>"><%= t.active ? 'activ' : 'inactiv' %></span>
            </button>

            <div class="trainer-accordion-body" id="trainer-actions-<%= t._id %>">
              <div class="trainer-detail-grid">
                <p><b>Nume:</b> <%= t.name %></p>
                <p><b>User:</b> <%= t.username %></p>
                <p><b>Status:</b> <%= t.active ? 'activ' : 'inactiv' %></p>
              </div>

              <details class="trainer-edit-box">
                <summary>Editează trainer</summary>
                <form action="/admin/trainers/<%= t._id %>/update" method="post" class="form-grid compact-form">
                  <label>Nume<input name="name" required value="<%= t.name %>"></label>
                  <label>User<input name="username" required value="<%= t.username %>"></label>
                  <label>Status
                    <select name="active">
                      <option value="true" <%= t.active ? 'selected' : '' %>>Activ</option>
                      <option value="false" <%= !t.active ? 'selected' : '' %>>Inactiv</option>
                    </select>
                  </label>
                  <button class="btn small primary" type="submit">Salvează trainer</button>
                </form>
              </details>

              <div class="actions trainer-inline-actions">
                <form action="/admin/trainers/<%= t._id %>/toggle" method="post">
                  <button class="btn small" type="submit"><%= t.active ? 'Dezactivează' : 'Activează' %></button>
                </form>

                <button
                  class="btn small danger js-delete-trainer"
                  type="button"
                  data-delete-url="/admin/trainers/<%= t._id %>/delete"
                  data-trainer-name="<%= t.name %>"
                >Șterge trainer</button>

                <form action="/admin/trainers/<%= t._id %>/password" method="post" class="inline-form password-form">
                  <input name="password" type="password" placeholder="Parolă nouă" class="password-input is-hidden" autocomplete="new-password">
                  <button class="btn small password-toggle" type="button">Schimbă</button>
                </form>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</section>

<div class="confirm-modal" id="deleteTrainerModal" aria-hidden="true">
  <div class="confirm-modal-panel" role="dialog" aria-modal="true" aria-labelledby="deleteTrainerTitle">
    <span class="pill red">Confirmare</span>
    <h2 id="deleteTrainerTitle">Ștergi trainerul?</h2>
    <p id="deleteTrainerText">Această acțiune va șterge trainerul și toate cursurile asociate lui.</p>
    <div class="actions confirm-actions">
      <button class="btn ghost" type="button" data-modal-cancel>Anulează</button>
      <button class="btn danger" type="button" data-modal-confirm>Șterge definitiv</button>
    </div>
  </div>
</div>

<section class="tab-panel" id="contabilitate">
  <section class="card luxe-card accounting-dashboard">
    <div class="section-title row-title accounting-title">
      <div>
        <span class="pill red">Contabilitate</span>
        <h2>Evidență lunară, anuală și calcul plată</h2>
        <p>Filtrează după trainer, filială, an și lună. Contabila vede rapid seminariile efectuate și calculează plata trainerului.</p>
        <a class="btn small ghost" href="/admin/exports/accounting.xlsx" id="accountingExportLink">Export Excel contabilitate</a>
      </div>
      <div class="accounting-total-box">
        <span>Total filtrat</span>
        <strong id="filteredTotal"><%= accounting.reduce((sum, item) => sum + item.total, 0) %></strong>
        <small>seminarii</small>
      </div>
    </div>

    <div class="accounting-filters">
      <label>Trainer
        <select id="accountingTrainerFilter">
          <option value="all">Toți trainerii</option>
          <% accounting.forEach(item => { %>
            <option value="<%= item.trainer._id %>"><%= item.trainer.name %></option>
          <% }) %>
        </select>
      </label>
      <label>Filială
        <select id="accountingLocationFilter">
          <option value="all">Toate filialele</option>
          <% [...new Set(accounting.flatMap(item => item.locations).filter(Boolean))].sort().forEach(location => { %>
            <option value="<%= location %>"><%= location %></option>
          <% }) %>
        </select>
      </label>
      <label>Curs
        <select id="accountingCourseFilter">
          <option value="all">Toate cursurile</option>
          <% accountingCourses.forEach(course => { %>
            <option value="<%= course %>"><%= course %></option>
          <% }) %>
        </select>
      </label>
      <label>An
        <select id="accountingYearFilter">
          <option value="all">Toți anii</option>
          <% [...new Set(accounting.flatMap(item => item.years))].sort((a,b)=>b-a).forEach(year => { %>
            <option value="<%= year %>"><%= year %></option>
          <% }) %>
        </select>
      </label>
      <label>Lună
        <select id="accountingMonthFilter">
          <option value="all">Toate lunile</option>
          <% ['Ianuarie','Februarie','Martie','Aprilie','Mai','Iunie','Iulie','August','Septembrie','Octombrie','Noiembrie','Decembrie'].forEach((month, idx) => { %>
            <option value="<%= idx %>"><%= month %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="accounting-list">
      <% accounting.forEach(item => { %>
        <% const dataPoints = item.courses.flatMap(course => course.points.map(point => course.name + '::' + point)); %>
        <article class="accounting-card luxe-mini-card"
          data-trainer-card="<%= item.trainer._id %>"
          data-location="<%= item.locations.join(',') || '' %>"
          data-total="<%= item.total %>"
          data-points="<%= dataPoints.join('|') %>">
          <div class="accounting-head">
            <div>
              <h3><%= item.trainer.name %></h3>
              <p><%= item.locations.length ? item.locations.join(', ') : 'Fără filiale alocate' %> · <%= item.reports.length %> rapoarte · <%= item.courses.length %> cursuri</p>
            </div>
            <strong><%= item.total %> seminarii</strong>
          </div>

          <div class="course-breakdown">
            <% if (item.courses.length) { %>
              <% item.courses.forEach(course => { %>
                <div class="course-line" data-course-name="<%= course.name %>" data-course-points="<%= course.points.join('|') %>" data-course-total="<%= course.total %>">
                  <span><%= course.name %></span>
                  <strong><%= course.total %> seminarii</strong>
                </div>
              <% }) %>
            <% } else { %>
              <div class="course-line empty"><span>Fără cursuri cu seminarii salvate</span><strong>0 seminarii</strong></div>
            <% } %>
          </div>

          <div class="year-strip">
            <% if (item.byYear.length) { %>
              <% item.byYear.forEach(y => { %>
                <span><b><%= y.year %></b> · <%= y.count %></span>
              <% }) %>
            <% } else { %>
              <span><b>Fără seminarii</b></span>
            <% } %>
          </div>

          <div class="months-grid big">
            <% item.selectedYearMonthly.forEach(m => { %>
              <span class="month-chip <%= m.count ? 'has-count' : '' %>" data-month-index="<%= m.index %>"><%= m.name.slice(0,3) %>: <b><%= m.count %></b></span>
            <% }) %>
          </div>

          <details class="accounting-series-list">
            <summary>Serii asociate (<%= item.reports.length %>)</summary>
            <div class="accounting-series-actions">
              <% item.reports.forEach(report => { %>
                <div class="accounting-series-row">
                  <div>
                    <strong><%= report.title %></strong>
                    <small><%= report.location || 'Fără filială' %> · <%= report.status === 'finalized' ? 'finalizat' : 'activ' %> · <%= report.seminars.length %> seminarii</small>
                  </div>
                  <div class="table-actions">
                    <a class="btn small ghost" href="/admin/reports/<%= report._id %>">Detalii</a>
                    <% if (report.status !== 'finalized') { %>
                      <form action="/admin/reports/<%= report._id %>/finalize" method="post">
                        <input type="hidden" name="returnTo" value="/admin#contabilitate">
                        <button class="btn small success" type="submit">Marchează ca finalizat</button>
                      </form>
                    <% } %>
                    <form action="/admin/reports/<%= report._id %>/delete" method="post" onsubmit="return confirm('Sigur vrei să ștergi seria «<%= String(report.title || '').replace(/'/g, '&#39;') %>»? Se vor șterge și seminariile completate.');">
                      <input type="hidden" name="returnTo" value="/admin#contabilitate">
                      <button class="btn small danger" type="submit">Șterge serie</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </details>

          <form class="pay-calc" oninput="this.querySelector('[data-total]').textContent = ((Number(this.commission.value)||0) * Number(this.closest('[data-trainer-card]').dataset.visibleTotal || this.closest('[data-trainer-card]').dataset.total || 0)).toFixed(2) + ' lei'">
            <label>Comision/seminar <input name="commission" type="number" step="0.01" min="0" placeholder="lei"></label>
            <span>Total plată: <strong data-total>0.00 lei</strong></span>
          </form>
          <a class="btn small ghost accounting-trainer-export" href="/admin/exports/accounting.xlsx?trainer=<%= item.trainer._id %>" data-trainer-export="<%= item.trainer._id %>">Export Excel</a>
        </article>
      <% }) %>
    </div>
  </section>
</section>

<%- include('../partials/footer') %>
