<%- include('../partials/header') %>
<section class="hero"><div><p class="eyebrow">raport</p><h1><%= report.title %></h1><p class="muted"><%= report.trainer.name %> · <%= report.location || report.trainer.location %></p></div><div class="stats"><div><b><%= stats.total %></b><span>seminarii</span></div><div><b><%= stats.commission %></b><span>lei/seminar</span></div><div><b><%= stats.paymentTotal %></b><span>lei total</span></div></div></section>
<section class="grid two"><div class="card"><h2>Seminarii pe luni</h2><div class="months"><% stats.monthly.forEach(m => { if (m.count > 0) { %><div><span><%= m.name %></span><b><%= m.count %></b></div><% } }) %></div></div><div class="card"><h2>Calcul plată</h2><form method="post" action="/admin/reports/<%= report._id %>/commission" class="stack"><label>Comision / seminar<input name="commission" type="number" step="0.01" value="<%= customCommission ?? stats.commission %>"></label><button class="primary">Recalculează</button></form><a class="ghost inline" href="/admin/reports/<%= report._id %>/export.xlsx">Export Excel</a><form method="post" action="/admin/reports/<%= report._id %>/status" class="inline-form"><input type="hidden" name="status" value="<%= report.status === 'active' ? 'finalized' : 'active' %>"><button class="ghost"><%= report.status === 'active' ? 'Marchează finalizat' : 'Redeschide raport' %></button></form></div></section>
<section class="card"><h2>Seminarii completate</h2><div class="table-wrap"><table><thead><tr><th>Data</th><th>Tema</th><th>Ore</th><th>Absenți</th><th>Probleme</th><th>Talentați</th><th>Observații</th></tr></thead><tbody><% report.seminars.forEach(s => { %><tr><td><%= new Date(s.date).toLocaleDateString('ro-RO') %></td><td><%= s.topic %></td><td><%= s.hours %></td><td><%= s.absents.join(', ') %></td><td><%= s.issues.join(', ') %></td><td><%= s.talents.join(', ') %></td><td><%= s.notes %></td></tr><% }) %></tbody></table></div></section>
<section class="card"><h2>Cursanți</h2><div class="chips"><% report.trainees.forEach(t => { %><span><%= t.name %></span><% }) %></div></section>
<%- include('../partials/footer') %>
