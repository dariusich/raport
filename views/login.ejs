<%- include('partials/header') %>
<section class="login-card">
  <div>
    <p class="eyebrow">platformă rapoarte</p>
    <h1>Autentificare</h1>
    <p class="muted">Trainerii își completează rapoartele, iar managerul/contabila vede automat statistici și plăți.</p>
  </div>
  <form method="post" action="/login" class="stack">
    <label>User<input name="username" autocomplete="username" required></label>
    <label>Parolă<input name="password" type="password" autocomplete="current-password" required></label>
    <button class="primary">Intră în cont</button>
  </form>
</section>
<%- include('partials/footer') %>
