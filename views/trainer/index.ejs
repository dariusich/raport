<%- include('../partials/header') %>

<section class="hero">
  <div>
    <p class="eyebrow">Trainer</p>
    <h1>Rapoartele mele</h1>
    <p class="hero-text">Completează rapoartele active. Cele finalizate rămân în arhivă.</p>
  </div>
</section>

<div class="report-grid">
  <% reports.forEach(r => { %>
    <a class="report-tile" href="/trainer/reports/<%= r._id %>">
      <span class="status <%= r.status %>"><%= r.status === 'active' ? 'activ' : 'finalizat' %></span>
      <h2><%= r.title %></h2>
      <p><%= r.location || 'fără filială' %></p>
      <strong><%= r.seminars.length %> seminarii completate</strong>
    </a>
  <% }) %>
</div>

<%- include('../partials/footer') %>
