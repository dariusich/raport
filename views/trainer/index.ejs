<%- include('../partials/header') %>

<%
  const seminarDayKey = (date) => {
    if (!date) return '';
    return new Date(date).toISOString().slice(0, 10);
  };

  const countUniqueSeminarDays = (report) => {
    const startKey = report.startDate ? seminarDayKey(report.startDate).slice(0, 7) : '';
    const endKey = report.endDate ? seminarDayKey(report.endDate).slice(0, 7) : '';

    const validDays = (report.seminars || [])
      .filter(s => s && s.date)
      .map(s => seminarDayKey(s.date))
      .filter(dateKey => {
        const monthKey = dateKey.slice(0, 7);
        return (!startKey || monthKey >= startKey) && (!endKey || monthKey <= endKey);
      });

    return new Set(validDays).size;
  };
%>

<section class="hero trainer-hero">
  <div>
    <p class="eyebrow">Trainer</p>
    <h1>Rapoartele mele</h1>
    <p class="hero-text">Alege seria, apoi luna în care vrei să adaugi ziua de seminar.</p>
  </div>
<div class="hero-stats compact">
  <div><strong><%= reports.filter(r => r.status === 'active').length %></strong><span>serii active</span></div>
  <div><strong><%= reports.reduce((sum, r) => sum + countUniqueSeminarDays(r), 0) %></strong><span>seminarii salvate</span></div>
</div>
</section>

<section class="card luxe-card">
  <div class="section-title">
    <span class="pill red">Serii în derulare</span>
    <h2>Alege cursul</h2>
    <p>Seriile tale active sunt afișate compact, ca să alegi rapid cursul și luna în care completezi seminarul.</p>
  </div>

  <div class="trainer-list-tools">
    <input id="seriesSearch" type="search" placeholder="Caută după curs sau filială...">
    <select id="seriesStatusFilter">
      <option value="active" selected>Active</option>
      <option value="all">Toate seriile</option>
      <option value="finalized">Finalizate</option>
    </select>
  </div>

  <div class="course-list" id="seriesList">
    <% reports.forEach(r => { %>
      <% const start = r.startDate ? new Date(r.startDate).toLocaleDateString('ro-RO') : ''; %>
      <% const end = r.endDate ? new Date(r.endDate).toLocaleDateString('ro-RO') : ''; %>
      <a class="course-row" href="/trainer/reports/<%= r._id %>" data-series-row data-title="<%= (r.title || '').toLowerCase() %>" data-location="<%= (r.location || '').toLowerCase() %>" data-status="<%= r.status %>">
        <div class="course-main">
          <span class="status <%= r.status %>"><%= r.status === 'active' ? 'activ' : 'finalizat' %></span>
          <h3><%= r.title %></h3>
          <p><%= r.location || 'fără filială' %><%= start || end ? ' · ' + start + (end ? ' - ' + end : '') : '' %></p>
        </div>
        <div class="course-meta">
          <strong><%= countUniqueSeminarDays(r) %></strong>
          <span>seminarii</span>
        </div>
      </a>
    <% }) %>
  </div>

  <div class="series-request-card">
    <span class="series-request-icon" aria-hidden="true">✉</span>
    <div>
      <span class="series-request-kicker">Solicitare</span>
      <h3>Nu vezi seria ta?</h3>
      <p>Dacă urmează să susții un curs sau ai început deja unul, dar seria nu apare în listă, trimite o solicitare către administrator.</p>
      <% if (seriesRequests.length) { %>
        <div class="series-request-open-list">
          <% seriesRequests.forEach(request => { %>
            <span><%= request.courseName %> · trimisă în <%= request.createdAt.toLocaleDateString('ro-RO') %></span>
          <% }) %>
        </div>
      <% } %>
      <button class="btn primary small" type="button" id="openSeriesRequestModal">Solicită serie</button>
    </div>
  </div>
</section>

<div class="series-request-modal" id="seriesRequestModal" aria-hidden="true">
  <section class="card series-request-modal-panel" role="dialog" aria-modal="true" aria-labelledby="seriesRequestTitle">
    <button class="modal-x" type="button" id="closeSeriesRequestModal" aria-label="Închide">×</button>
    <span class="pill red">Solicitare serie</span>
    <h2 id="seriesRequestTitle">Trimite solicitare către administrator</h2>
    <p>Completează ce știi acum. Datele ajută administratorul să identifice rapid seria care lipsește.</p>
    <form action="/trainer/series-requests" method="post" class="form-grid">
      <label>Nume curs <input name="courseName" required placeholder="Ex: Cosmetician, Frizer, Masaj, Coafor..."></label>
      <div class="inline-2">
        <label>Data început <input name="startDate" type="date"></label>
        <label>Data final <input name="endDate" type="date"></label>
      </div>
      <label>Filială <input name="location" value="<%= currentUser.location || '' %>" placeholder="Ex: Iași, Sibiu, Bacău"></label>
      <label>Observații
        <textarea name="notes" rows="3" placeholder="Ex: cursul a început deja / urmează să înceapă / nu apare în lista mea."></textarea>
      </label>
      <button class="btn primary full" type="submit">Trimite solicitarea</button>
    </form>
  </section>
</div>


<script>
  const seriesSearch = document.getElementById('seriesSearch');
  const seriesStatusFilter = document.getElementById('seriesStatusFilter');
  const seriesRows = Array.from(document.querySelectorAll('[data-series-row]'));
  function updateSeriesList() {
    const q = (seriesSearch?.value || '').toLowerCase().trim();
    const status = seriesStatusFilter?.value || 'all';
    seriesRows.forEach((row) => {
      const matchesText = !q || row.dataset.title.includes(q) || row.dataset.location.includes(q);
      const matchesStatus = status === 'all' || row.dataset.status === status;
      row.style.display = matchesText && matchesStatus ? '' : 'none';
    });
  }
  seriesSearch?.addEventListener('input', updateSeriesList);
  seriesStatusFilter?.addEventListener('change', updateSeriesList);
  updateSeriesList();

  const seriesRequestModal = document.getElementById('seriesRequestModal');
  const openSeriesRequestModal = document.getElementById('openSeriesRequestModal');
  const closeSeriesRequestModal = document.getElementById('closeSeriesRequestModal');
  const closeRequestModal = () => {
    seriesRequestModal?.classList.remove('open');
    seriesRequestModal?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
  };
  openSeriesRequestModal?.addEventListener('click', () => {
    seriesRequestModal?.classList.add('open');
    seriesRequestModal?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('modal-open');
  });
  closeSeriesRequestModal?.addEventListener('click', closeRequestModal);
  seriesRequestModal?.addEventListener('click', (event) => {
    if (event.target === seriesRequestModal) closeRequestModal();
  });
</script>

<%- include('../partials/footer') %>
