<%- include('../partials/header') %>

<%
  const seminarDayKey = (date) => {
    if (!date) return '';
    return new Date(date).toISOString().slice(0, 10);
  };

  const countUniqueSeminarDays = (report) => {
    const startKey = report.startDate ? seminarDayKey(report.startDate).slice(0, 7) : '';
    const endKey = report.endDate ? seminarDayKey(report.endDate).slice(0, 7) : '';

    const validDays = (report.seminars || [])
      .filter(s => s && s.date)
      .map(s => seminarDayKey(s.date))
      .filter(dateKey => {
        const monthKey = dateKey.slice(0, 7);
        return (!startKey || monthKey >= startKey) && (!endKey || monthKey <= endKey);
      });

    return new Set(validDays).size;
  };
%>

<section class="hero trainer-hero">
  <div>
    <p class="eyebrow">Trainer</p>
    <h1>Rapoartele mele</h1>
    <p class="hero-text">Alege seria, apoi luna în care vrei să adaugi ziua de seminar.</p>
  </div>
<div class="hero-stats compact">
  <div><strong><%= reports.filter(r => r.status === 'active').length %></strong><span>serii active</span></div>
  <div><strong><%= reports.reduce((sum, r) => sum + countUniqueSeminarDays(r), 0) %></strong><span>seminarii salvate</span></div>
</div>
</section>

<section class="card luxe-card">
  <div class="section-title">
    <span class="pill red">Serii în derulare</span>
    <h2>Alege cursul</h2>
    <p>Seriile tale active sunt afișate compact, ca să alegi rapid cursul și luna în care completezi seminarul.</p>
  </div>

  <div class="trainer-list-tools">
    <input id="seriesSearch" type="search" placeholder="Caută după curs sau filială...">
    <select id="seriesStatusFilter">
      <option value="all">Toate seriile</option>
      <option value="active">Active</option>
      <option value="finalized">Finalizate</option>
    </select>
  </div>

  <div class="course-list" id="seriesList">
    <% reports.forEach(r => { %>
      <% const start = r.startDate ? new Date(r.startDate).toLocaleDateString('ro-RO') : ''; %>
      <% const end = r.endDate ? new Date(r.endDate).toLocaleDateString('ro-RO') : ''; %>
      <a class="course-row" href="/trainer/reports/<%= r._id %>" data-series-row data-title="<%= (r.title || '').toLowerCase() %>" data-location="<%= (r.location || '').toLowerCase() %>" data-status="<%= r.status %>">
        <div class="course-main">
          <span class="status <%= r.status %>"><%= r.status === 'active' ? 'activ' : 'finalizat' %></span>
          <h3><%= r.title %></h3>
          <p><%= r.location || 'fără filială' %><%= start || end ? ' · ' + start + (end ? ' - ' + end : '') : '' %></p>
        </div>
        <div class="course-meta">
          <strong><%= countUniqueSeminarDays(r) %></strong>
          <span>seminarii</span>
        </div>
      </a>
    <% }) %>
  </div>
</section>


<script>
  const seriesSearch = document.getElementById('seriesSearch');
  const seriesStatusFilter = document.getElementById('seriesStatusFilter');
  const seriesRows = Array.from(document.querySelectorAll('[data-series-row]'));
  function updateSeriesList() {
    const q = (seriesSearch?.value || '').toLowerCase().trim();
    const status = seriesStatusFilter?.value || 'all';
    seriesRows.forEach((row) => {
      const matchesText = !q || row.dataset.title.includes(q) || row.dataset.location.includes(q);
      const matchesStatus = status === 'all' || row.dataset.status === status;
      row.style.display = matchesText && matchesStatus ? '' : 'none';
    });
  }
  seriesSearch?.addEventListener('input', updateSeriesList);
  seriesStatusFilter?.addEventListener('change', updateSeriesList);
</script>

<%- include('../partials/footer') %>
