<%- include('../partials/header') %>

<section class="report-hero">
  <div>
    <p class="eyebrow">Formular raport trainer</p>
    <h1><%= report.title %></h1>
    <p><%= report.location %> · <%= report.status === 'active' ? 'Raport activ' : 'Raport finalizat' %></p>
  </div>
  <div class="hero-stats compact">
    <div><strong><%= report.trainees.length %></strong><span>cursanți</span></div>
    <div><strong><%= report.seminars.length %></strong><span>seminarii</span></div>
  </div>
</section>

<section class="trainer-layout">
  <aside class="trainee-panel">
    <div class="sticky-card">
      <h2>Lista cursanți</h2>
      <p>Mereu la vedere pentru completare rapidă.</p>
      <div class="trainee-list">
        <% report.trainees.forEach((t, index) => { %>
          <span><b><%= index + 1 %>.</b> <%= t.name %></span>
        <% }) %>
      </div>
    </div>
  </aside>

  <div class="report-panel">
    <% if (report.status === 'active') { %>
      <form action="/trainer/reports/<%= report._id %>/seminars" method="post" class="card form-grid seminar-form">
        <div class="section-title"><span class="pill green">Seminar</span><h2>Adaugă zi de curs</h2></div>
        <div class="inline-3">
          <label>Data <input name="date" type="date" required></label>
          <label>Ora început <input name="startTime" type="time"></label>
          <label>Ora final <input name="endTime" type="time"></label>
        </div>
        <label>Activitate desfășurată conform programei
          <textarea name="activity" rows="3" placeholder="Ex: Masaj relaxare - tehnici practice, recapitulare, demonstrație..."></textarea>
        </label>
        <label>Conform programei
          <select name="activityConform">
            <option value="da">Da</option>
            <option value="partial">Parțial</option>
            <option value="nu">Nu</option>
          </select>
        </label>
        <label>Absenți / nume prenume <small>Ține CTRL apăsat pe desktop pentru selectare multiplă.</small>
          <select name="absents" multiple size="6">
            <% report.trainees.forEach(t => { %><option value="<%= t.name %>"><%= t.name %></option><% }) %>
          </select>
        </label>
        <label>Cursanți cu probleme <small>Persoane care deranjează, absentează, restante plată, antitalente etc.</small>
          <select name="issues" multiple size="6">
            <% report.trainees.forEach(t => { %><option value="<%= t.name %>"><%= t.name %></option><% }) %>
          </select>
        </label>
        <label>Exemplificați problemele
          <textarea name="issuesDetails" rows="3" placeholder="Detalii scurte, clare, utile pentru manager."></textarea>
        </label>
        <label>Starea sălii la venire / plecare
          <textarea name="roomState" rows="2" placeholder="Ex: sala curată la venire, lăsată în ordine la plecare."></textarea>
        </label>
        <label>Obiecte defecte / lipsă
          <textarea name="brokenObjects" rows="2" placeholder="Scrie 'Nu este cazul' dacă nu sunt probleme."></textarea>
        </label>
        <div class="inline-2">
          <label>Cantitatea de produse
            <select name="productsQuantity">
              <option value="suficienta">Suficientă</option>
              <option value="insuficienta">Insuficientă</option>
            </select>
          </label>
          <label>Poze/filmulețe trimise
            <select name="mediaSent">
              <option value="da">Da</option>
              <option value="nu">Nu</option>
            </select>
          </label>
        </div>
        <label>Persoana/persoanele talentate din serie
          <select name="talents" multiple size="6">
            <% report.trainees.forEach(t => { %><option value="<%= t.name %>"><%= t.name %></option><% }) %>
          </select>
        </label>
        <label>Observații finale
          <textarea name="notes" rows="3"></textarea>
        </label>
        <button class="btn primary full" type="submit">Salvează seminar</button>
      </form>

      <form action="/trainer/reports/<%= report._id %>/finalize" method="post" class="finalize-box">
        <p>Finalizează raportul doar când nu mai ai completări de făcut.</p>
        <button class="btn danger" type="submit">Finalizează raport</button>
      </form>
    <% } else { %>
      <div class="card"><h2>Raport finalizat</h2><p>Raportul este finalizat și nu mai poate fi modificat.</p></div>
    <% } %>

    <section class="card">
      <div class="section-title"><span class="pill">Istoric</span><h2>Seminarii salvate</h2></div>
      <div class="seminar-cards">
        <% report.seminars.forEach(s => { %>
          <article class="seminar-card">
            <h3><%= new Date(s.date).toLocaleDateString('ro-RO') %> · <%= s.startTime || '' %><%= s.endTime ? ' - ' + s.endTime : '' %></h3>
            <p><b>Activitate:</b> <%= s.activity || '-' %></p>
            <p><b>Absenți:</b> <%= s.absents.join(', ') || '-' %></p>
            <p><b>Probleme:</b> <%= s.issues.join(', ') || '-' %></p>
            <p><b>Talentați:</b> <%= s.talents.join(', ') || '-' %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </div>
</section>

<%- include('../partials/footer') %>
