<%- include('../partials/header') %>

<%
const seminarDayKey = (date) => {
  if (!date) return '';
  return new Date(date).toISOString().slice(0, 10);
};

const courseMonthKeys = new Set(months.map(m => m.key));

const countUniqueSeminarDays = (seminars = []) => {
  const validDays = seminars
    .filter(s => s && s.date)
    .map(s => seminarDayKey(s.date))
    .filter(dateKey => dateKey && courseMonthKeys.has(dateKey.slice(0, 7)));

  return new Set(validDays).size;
};
%>

<style>
  .seminar-calendar {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 8px;
    margin-top: 18px;
  }

  .calendar-head {
    font-size: 12px;
    font-weight: 800;
    color: #7a2030;
    text-align: center;
    padding: 8px 0;
    text-transform: uppercase;
  }

  .calendar-day {
    min-height: 76px;
    border: 1px solid rgba(196, 31, 45, 0.18);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.75);
    padding: 10px;
    text-decoration: none;
    color: #24242f;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: 0.2s ease;
    cursor: pointer;
  }

  .calendar-day:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 25px rgba(178, 24, 34, 0.12);
    border-color: rgba(196, 31, 45, 0.45);
  }

  .calendar-day.empty {
    opacity: 0.25;
    pointer-events: none;
  }

  .calendar-day.saved {
    background: linear-gradient(135deg, #0f9f5a, #13c978);
    color: #fff;
    border-color: #0f9f5a;
  }

  .calendar-day.selected {
    outline: 3px solid rgba(196, 31, 45, 0.22);
  }

  .calendar-day strong {
    font-size: 18px;
  }

  .calendar-day span {
    font-size: 12px;
    font-weight: 800;
  }

  .calendar-info {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 14px;
    color: #6b6878;
    font-size: 14px;
  }

  .calendar-dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    display: inline-block;
    margin-right: 6px;
    vertical-align: middle;
  }

  .calendar-dot.green {
    background: #13c978;
  }

  .calendar-dot.empty {
    background: #fff;
    border: 1px solid rgba(196, 31, 45, 0.35);
  }

  .selected-date-box {
    margin: 0 0 18px;
    padding: 14px 16px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(196, 31, 45, 0.09), rgba(242, 92, 66, 0.08));
    border: 1px solid rgba(196, 31, 45, 0.16);
    font-weight: 800;
    color: #7a2030;
  }



  .seminar-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 18px;
    background: rgba(18, 18, 24, 0.48);
    backdrop-filter: blur(6px);
  }

  .seminar-modal.open { display: flex; }

  .seminar-modal-panel {
    width: min(920px, 100%);
    max-height: 92vh;
    overflow: auto;
    border-radius: 28px;
    background: #fffaf8;
    box-shadow: 0 28px 80px rgba(60, 20, 28, 0.28);
    position: relative;
  }

  .seminar-modal-close {
    position: sticky;
    top: 12px;
    float: right;
    z-index: 2;
    width: 42px;
    height: 42px;
    margin: 12px 12px 0 0;
    border: 1px solid rgba(196, 31, 45, 0.22);
    border-radius: 999px;
    background: #fff;
    color: #9b1632;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(178, 24, 34, 0.12);
  }

  .seminar-modal .seminar-form {
    margin: 0;
    border-radius: 28px;
    box-shadow: none;
  }

  .trainee-compact {
    border: 1px solid rgba(196, 31, 45, 0.16);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.68);
    padding: 0;
    overflow: hidden;
  }

  .trainee-compact summary {
    cursor: pointer;
    padding: 14px 16px;
    font-weight: 900;
    color: #7a2030;
    list-style: none;
  }

  .trainee-compact summary::-webkit-details-marker { display: none; }

  .trainee-compact-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 8px;
    padding: 0 16px 16px;
  }

  .trainee-chip {
    border: 1px solid rgba(196, 31, 45, 0.13);
    border-radius: 999px;
    padding: 8px 10px;
    background: #fff;
    font-size: 13px;
    font-weight: 800;
  }

  .multi-select summary {
    cursor: pointer;
    border: 1px solid rgba(196, 31, 45, 0.18);
    border-radius: 14px;
    padding: 13px 14px;
    background: #fff;
    font-weight: 800;
    color: #7a2030;
    list-style: none;
  }

  .multi-select summary::-webkit-details-marker { display: none; }

  .multi-menu {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 8px;
    max-height: 230px;
    overflow: auto;
    padding: 10px 0 0;
  }

  .multi-menu label {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(196, 31, 45, 0.13);
    border-radius: 14px;
    background: #fff;
    padding: 10px;
    font-size: 13px;
    font-weight: 800;
  }

  body.modal-open { overflow: hidden; }

  .save-success-modal {
    position: fixed;
    inset: 0;
    z-index: 10050;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: linear-gradient(135deg, #fffaf7, #ffffff);
    backdrop-filter: blur(8px);
  }

  .save-success-modal.open {
    display: flex;
    animation: modalFadeIn 0.22s ease both;
  }

  .save-success-card {
    width: min(520px, 100%);
    border: 1px solid rgba(19, 201, 120, 0.28);
    background: linear-gradient(135deg, rgba(19, 201, 120, 0.13), rgba(255, 255, 255, 0.98));
    box-shadow: 0 28px 70px rgba(19, 201, 120, 0.18);
    margin: 0;
    transform-origin: center;
  }

  .save-success-modal.open .save-success-card {
    animation: modalScaleIn 0.26s cubic-bezier(.2,.8,.2,1) both;
  }

  .save-success-card h2 {
    color: #0f7a4a;
    margin-bottom: 8px;
  }

  .save-success-card p {
    color: #5c6870;
    margin-bottom: 16px;
  }

  .seminar-delete-modal {
    position: fixed;
    inset: 0;
    z-index: 10060;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(18, 18, 24, 0.52);
    backdrop-filter: blur(8px);
  }

  .seminar-delete-modal.open {
    display: flex;
    animation: modalFadeIn 0.22s ease both;
  }

  .seminar-delete-card {
    width: min(460px, 100%);
    margin: 0;
    animation: modalScaleIn 0.26s cubic-bezier(.2,.8,.2,1) both;
  }

  .field-error {
    border-color: #b91c1c !important;
    box-shadow: 0 0 0 3px rgba(185, 28, 28, 0.10);
  }

  .save-success-icon {
    width: 62px;
    height: 62px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: #13c978;
    color: #fff;
    font-size: 34px;
    font-weight: 900;
    margin-bottom: 16px;
    box-shadow: 0 18px 34px rgba(19, 201, 120, 0.26);
  }

  @keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes modalScaleIn {
    from { opacity: 0; transform: translateY(16px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }


  @media (max-width: 720px) {
    .seminar-calendar {
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 8px;
      width: 100%;
    }

    .calendar-head { display: none; }

    .calendar-day {
      min-height: 68px;
      border-radius: 14px;
      padding: 8px 6px;
      align-items: center;
      text-align: center;
      min-width: 0;
    }

    .calendar-day.empty { display: none; }

    .calendar-day span {
      max-width: 100%;
      overflow-wrap: anywhere;
      line-height: 1.2;
    }

    .calendar-day strong {
      font-size: 15px;
    }

    .calendar-day span {
      font-size: 10px;
    }

    .trainee-panel { display: none; }

    .seminar-modal {
      align-items: flex-end;
      padding: 0;
    }

    .seminar-modal-panel {
      width: 100%;
      max-width: 100%;
      max-height: 92vh;
      border-radius: 26px 26px 0 0;
    }

    .seminar-modal .seminar-form {
      width: 100%;
      max-width: 100%;
      border-radius: 26px 26px 0 0;
      padding: 22px 18px 28px;
    }

    .multi-menu {
      grid-template-columns: 1fr;
      max-height: 190px;
    }
  }
</style>

<div class="back-row">
  <a class="btn ghost" href="/trainer">← Înapoi la toate cursurile alocate</a>
</div>

<section class="report-hero compact-course-hero">
  <div>
    <p class="eyebrow">Serie alocată</p>
    <h1><%= report.title %></h1>
    <p>
      <%= report.location %>
      <% if (report.startDate || report.endDate) { %>
        · <%= report.startDate ? new Date(report.startDate).toLocaleDateString('ro-RO') : '' %>
        <%= report.endDate ? ' - ' + new Date(report.endDate).toLocaleDateString('ro-RO') : '' %>
      <% } %>
    </p>
  </div>
  <div class="hero-stats compact">
    <div><strong><%= report.trainees.length %></strong><span>cursanți</span></div>
    <div><strong><%= countUniqueSeminarDays(report.seminars) %></strong><span>seminarii</span></div>
  </div>
</section>

<section class="card luxe-card trainer-months-card <%= selectedMonth && !showMonths ? 'is-stacked-hidden' : '' %>" id="months-section">
  <div class="section-title">
    <span class="pill red">Lunile cursului</span>
    <h2>Alege luna pentru completare</h2>
    <p>Se afișează doar lunile din perioada seriei.</p>
  </div>

  <div class="month-list-trainer">
    <% months.forEach(m => { %>
      <% const count = countUniqueSeminarDays(report.seminars.filter(s => seminarDayKey(s.date).startsWith(m.key))); %>
      <a class="month-row <%= selectedMonth === m.key ? 'active' : '' %>" href="/trainer/reports/<%= report._id %>?month=<%= m.key %>#calendar-section">
        <div>
          <strong><%= m.label %></strong>
          <span><%= m.year %></span>
        </div>
        <em><%= count %> seminarii</em>
      </a>
    <% }) %>
  </div>
</section>

<% if (selectedMonth && !showMonths) { %>
  <%
    const [calendarYear, calendarMonth] = selectedMonth.split('-').map(Number);
    const firstDay = new Date(calendarYear, calendarMonth - 1, 1);
    const daysInMonth = new Date(calendarYear, calendarMonth, 0).getDate();
    const startOffset = (firstDay.getDay() + 6) % 7;
const seminarsByDate = {};

seminarsInMonth.forEach(s => {
  const key = new Date(s.date).toISOString().slice(0, 10);
  seminarsByDate[key] = s;
});

    const selectedDateKey = selectedSeminar ? seminarDayKey(selectedSeminar.date) : '';
    const weekdayLabels = ['Lun', 'Mar', 'Mie', 'Joi', 'Vin', 'Sâm', 'Dum'];
  %>

  <section class="trainer-layout" id="calendar-section" tabindex="-1">
    <aside class="trainee-panel">
      <div class="sticky-card">
        <h2>Lista cursanți</h2>
        <p>Mereu la vedere pentru completare rapidă.</p>
        <div class="trainee-list">
          <% report.trainees.forEach((t, index) => { %>
            <span><b><%= index + 1 %>.</b> <%= t.name %></span>
          <% }) %>
        </div>
      </div>
    </aside>

    <div class="report-panel">
      <div class="save-success-modal <%= saveSuccess ? 'open' : '' %>" id="saveSuccessModal" aria-hidden="<%= saveSuccess ? 'false' : 'true' %>">
        <section class="card save-success-card" id="save-success" role="dialog" aria-modal="true" aria-labelledby="saveSuccessTitle">
          <div class="save-success-icon">✓</div>
          <h2 id="saveSuccessTitle">Seminarul din data <span id="saveSuccessDate"><%= savedDateDisplay || 'selectată' %></span> a fost salvat cu succes!</h2>
          <p>Alege următorul pas pentru completarea raportului.</p>
          <div class="actions">
            <button class="btn primary" type="button" id="successAnotherDay">Completează altă zi</button>
            <a class="btn ghost" href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&showMonths=1#months-section">Schimbă luna</a>
            <a class="btn ghost" href="/trainer">Revenire la seriile alocate</a>
          </div>
        </section>
      </div>

      <section class="card history-card">
        <div class="mobile-stack-back">
          <a class="btn ghost" href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&showMonths=1#months-section">← Înapoi la luni</a>
        </div>

        <div class="section-title row-title">
          <div>
            <span class="pill green">Calendar seminar</span>
            <h2>Calendar <%= selectedMonthInfo ? selectedMonthInfo.label + ' ' + selectedMonthInfo.year : 'luna selectată' %></h2>
            <p>Alege ziua seminarului. Zilele completate apar cu verde.</p>
          </div>
          <strong class="pill red"><%= countUniqueSeminarDays(seminarsInMonth) %> salvate</strong>
        </div>

        <div class="calendar-info">
          <span><i class="calendar-dot green"></i> Seminar completat</span>
          <span><i class="calendar-dot empty"></i> Zi disponibilă</span>
        </div>

        <div class="seminar-calendar">
          <% weekdayLabels.forEach(day => { %>
            <div class="calendar-head"><%= day %></div>
          <% }) %>

          <% for (let i = 0; i < startOffset; i++) { %>
            <div class="calendar-day empty"></div>
          <% } %>

          <% for (let day = 1; day <= daysInMonth; day++) { %>
            <%
              const dateKey = `${calendarYear}-${String(calendarMonth).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
              const savedSeminar = seminarsByDate[dateKey];
            %>

            <% if (savedSeminar) { %>
              <a
                class="calendar-day saved <%= selectedDateKey === dateKey ? 'selected' : '' %>"
                data-date="<%= dateKey %>"
                href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&seminar=<%= savedSeminar._id %>#calendar-section"
                title="Vezi detalii seminar"
              >
                <strong><%= day %></strong>
                <span><%= savedSeminar.startTime || 'salvat' %><%= savedSeminar.endTime ? ' - ' + savedSeminar.endTime : '' %></span>
              </a>
            <% } else { %>
              <button
                type="button"
                class="calendar-day js-pick-day"
                data-date="<%= dateKey %>"
                title="Adaugă seminar în această zi"
              >
                <strong><%= day %></strong>
                <span>Adaugă</span>
              </button>
            <% } %>
          <% } %>
        </div>
      </section>

      <% if (selectedSeminar && !editMode) { %>
        <section class="card seminar-detail">
          <div class="section-title row-title">
            <div>
              <span class="pill red">Detalii seminar</span>
              <h2><%= new Date(selectedSeminar.date).toLocaleDateString('ro-RO') %></h2>
            </div>
<div class="actions" data-testid="seminar-actions">
  <a class="btn primary" data-testid="seminar-edit-btn"
     href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&seminar=<%= selectedSeminar._id %>&edit=1#calendar-section">
    Modifică
  </a>

  <button
    class="btn danger js-delete-seminar"
    type="button"
    data-testid="seminar-delete-btn"
    data-delete-url="/trainer/reports/<%= report._id %>/seminars/<%= selectedSeminar._id %>/delete?month=<%= selectedMonth %>"
    data-date="<%= new Date(selectedSeminar.date).toLocaleDateString('ro-RO') %>"
  >Șterge</button>
</div>

          <div class="detail-grid">
            <p><b>Program:</b> <%= selectedSeminar.startTime || '-' %><%= selectedSeminar.endTime ? ' - ' + selectedSeminar.endTime : '' %></p>
            <p><b>Activitate:</b> <%= selectedSeminar.activity || '-' %></p>
            <p><b>Absenți:</b> <%= selectedSeminar.absents.join(', ') || '-' %></p>
            <p><b>Cursanți cu probleme:</b> <%= selectedSeminar.issues.join(', ') || '-' %></p>
            <p><b>Detalii probleme:</b> <%= selectedSeminar.issuesDetails || '-' %></p>
            <p><b>Starea sălii:</b> <%= selectedSeminar.roomState || '-' %></p>
            <p><b>Obiecte defecte/lipsă:</b> <%= selectedSeminar.brokenObjects || '-' %></p>
            <p><b>Produse:</b> <%= selectedSeminar.productsQuantity || '-' %></p>
            <p><b>Poze/filmulețe:</b> <%= selectedSeminar.mediaSent || '-' %></p>
            <p><b>Talentați:</b> <%= selectedSeminar.talents.join(', ') || '-' %></p>
            <p><b>Observații:</b> <%= selectedSeminar.notes || '-' %></p>
          </div>
        </section>
      <% } else if (report.status === 'active') { %>
        <% const formSeminar = editMode && selectedSeminar ? selectedSeminar : null; %>

        <div class="seminar-modal <%= formSeminar ? 'open' : '' %>" id="seminarModal" aria-hidden="<%= formSeminar ? 'false' : 'true' %>">
          <div class="seminar-modal-panel" role="dialog" aria-modal="true" aria-labelledby="seminarFormTitle">
            <button type="button" class="seminar-modal-close" id="seminarModalClose" aria-label="Închide formularul">×</button>

            <form action="/trainer/reports/<%= report._id %>/seminars" method="post" class="card form-grid seminar-form" id="seminarForm" novalidate data-ajax-save="1" data-report-id="<%= report._id %>" data-selected-month="<%= selectedMonth %>">
          <input type="hidden" name="selectedMonth" value="<%= selectedMonth %>">
          <% if (formSeminar) { %>
            <input type="hidden" name="seminarId" value="<%= formSeminar._id %>">
          <% } %>

          <div class="section-title">
            <span class="pill green"><%= formSeminar ? 'Modificare' : 'Seminar' %></span>
            <h2 id="seminarFormTitle"><%= formSeminar ? 'Modifică ziua de curs' : 'Adaugă zi de curs' %></h2>
            <p><%= formSeminar ? 'Actualizează informațiile pentru seminarul selectat.' : 'Selectează ziua din calendar, apoi completează detaliile seminarului.' %></p>
          </div>

          <div class="selected-date-box" id="selectedDateBox">
            Zi selectată:
            <span id="selectedDateText">
              <%= formSeminar ? new Date(formSeminar.date).toLocaleDateString('ro-RO') : 'alege o zi din calendar' %>
            </span>
          </div>

          <details class="trainee-compact">
            <summary>Lista cursanți din serie (<%= report.trainees.length %>)</summary>
            <div class="trainee-compact-list">
              <% report.trainees.forEach((t, index) => { %>
                <span class="trainee-chip"><%= index + 1 %>. <%= t.name %></span>
              <% }) %>
            </div>
          </details>

          <div class="inline-3">
            <label>Data
              <input
                id="seminarDateInput"
                name="date"
                type="date"
                required
                value="<%= formSeminar ? dateInputValue(formSeminar.date) : '' %>"
                min="<%= selectedMonth %>-01"
                max="<%= selectedMonth %>-<%= String(daysInMonth).padStart(2, '0') %>"
              >
            </label>
            <label>Ora început <input name="startTime" type="time" required value="<%= formSeminar ? formSeminar.startTime : '' %>"></label>
            <label>Ora final <input name="endTime" type="time" required value="<%= formSeminar ? formSeminar.endTime : '' %>"></label>
          </div>

          <label>Activitate desfășurată
            <textarea name="activity" rows="3" placeholder="Opțional: Ex: Masaj relaxare - tehnici practice, recapitulare, demonstrație..."><%= formSeminar ? formSeminar.activity : '' %></textarea>
            <small>Opțional. Pentru salvare sunt obligatorii doar data, ora de început și ora finală.</small>
          </label>

          <label>Absenți / nume prenume
            <details class="multi-select" data-multi-select>
              <summary data-default="Selectează absenții">Selectează absenții</summary>
              <div class="multi-menu">
                <% report.trainees.forEach(t => { %>
                  <label><input type="checkbox" name="absents" value="<%= t.name %>" <%= formSeminar && formSeminar.absents.includes(t.name) ? 'checked' : '' %>> <%= t.name %></label>
                <% }) %>
              </div>
            </details>
          </label>

          <label>Cursanți cu probleme
            <small>Persoane care deranjează cursul, absentează, sunt restante la plată dar frecventează cursul sau au dificultăți mari.</small>
            <details class="multi-select" data-multi-select>
              <summary data-default="Selectează cursanții cu probleme">Selectează cursanții cu probleme</summary>
              <div class="multi-menu">
                <% report.trainees.forEach(t => { %>
                  <label><input type="checkbox" name="issues" value="<%= t.name %>" <%= formSeminar && formSeminar.issues.includes(t.name) ? 'checked' : '' %>> <%= t.name %></label>
                <% }) %>
              </div>
            </details>
          </label>

          <label>Exemplificați problemele
            <textarea name="issuesDetails" rows="3" placeholder="Detalii scurte și clare: ce s-a întâmplat, când, ce trebuie urmărit."><%= formSeminar ? formSeminar.issuesDetails : '' %></textarea>
          </label>

          <label>Starea sălii la venire / plecare
            <textarea name="roomState" rows="2" placeholder="Ex: sala curată la venire, lăsată în ordine la plecare."><%= formSeminar ? formSeminar.roomState : '' %></textarea>
          </label>

          <label>Obiecte defecte / lipsă
            <textarea name="brokenObjects" rows="2" placeholder="Scrie 'Nu este cazul' dacă nu sunt probleme."><%= formSeminar ? formSeminar.brokenObjects : '' %></textarea>
          </label>

          <div class="inline-2">
            <label>Cantitatea de produse
              <select name="productsQuantity">
                <option value="" <%= !formSeminar || !formSeminar.productsQuantity ? 'selected' : '' %>>Opțional</option>
                <option value="suficienta" <%= formSeminar && formSeminar.productsQuantity === 'suficienta' ? 'selected' : '' %>>Suficientă</option>
                <option value="insuficienta" <%= formSeminar && formSeminar.productsQuantity === 'insuficienta' ? 'selected' : '' %>>Insuficientă</option>
              </select>
            </label>

            <label>Poze/filmulețe trimise din cadrul cursului
              <select name="mediaSent">
                <option value="" <%= !formSeminar || !formSeminar.mediaSent ? 'selected' : '' %>>Opțional</option>
                <option value="da" <%= formSeminar && formSeminar.mediaSent === 'da' ? 'selected' : '' %>>Da</option>
                <option value="nu" <%= formSeminar && formSeminar.mediaSent === 'nu' ? 'selected' : '' %>>Nu</option>
              </select>
            </label>
          </div>

          <label>Persoana/persoanele talentate din serie
            <details class="multi-select" data-multi-select>
              <summary data-default="Selectează persoanele talentate">Selectează persoanele talentate</summary>
              <div class="multi-menu">
                <% report.trainees.forEach(t => { %>
                  <label><input type="checkbox" name="talents" value="<%= t.name %>" <%= formSeminar && formSeminar.talents.includes(t.name) ? 'checked' : '' %>> <%= t.name %></label>
                <% }) %>
              </div>
            </details>
          </label>

          <label>Observații finale
            <textarea name="notes" rows="3" placeholder="Orice informație utilă pentru manager / contabilitate."><%= formSeminar ? formSeminar.notes : '' %></textarea>
          </label>

          <div class="actions">
            <button class="btn primary" type="submit"><%= formSeminar ? 'Salvează modificările' : 'Salvează seminar' %></button>
            <% if (formSeminar) { %>
              <a class="btn ghost" href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&seminar=<%= formSeminar._id %>#calendar-section">Renunță</a>
            <% } %>
          </div>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </section>
<% } %>

<div class="seminar-delete-modal" id="seminarDeleteModal" aria-hidden="true">
  <section class="card seminar-delete-card" role="dialog" aria-modal="true" aria-labelledby="seminarDeleteTitle">
    <span class="pill red">Confirmare</span>
    <h2 id="seminarDeleteTitle">Ștergi seminarul?</h2>
    <p id="seminarDeleteText">Această acțiune nu poate fi anulată.</p>
    <div class="actions">
      <button class="btn ghost" type="button" id="seminarDeleteCancel">Anulează</button>
      <button class="btn danger" type="button" id="seminarDeleteConfirm">Șterge seminar</button>
    </div>
  </section>
</div>

<script>
  const seminarModal = document.getElementById('seminarModal');
  const seminarModalClose = document.getElementById('seminarModalClose');

  function openSeminarModal() {
    if (!seminarModal) return;
    seminarModal.classList.add('open');
    seminarModal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('modal-open');
  }

  function closeSeminarModal() {
    if (!seminarModal) return;
    seminarModal.classList.remove('open');
    seminarModal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
  }

  function refreshMultiSelectSummary(details) {
    const summary = details.querySelector('summary');
    if (!summary) return;
    const defaultText = summary.dataset.default || summary.textContent.trim();
    const checked = details.querySelectorAll('input[type="checkbox"]:checked');
    summary.textContent = checked.length ? `${defaultText} (${checked.length})` : defaultText;
  }

  document.querySelectorAll('[data-multi-select]').forEach((details) => {
    refreshMultiSelectSummary(details);
    details.querySelectorAll('input[type="checkbox"]').forEach((input) => {
      input.addEventListener('change', () => refreshMultiSelectSummary(details));
    });
  });

  document.querySelectorAll('.js-pick-day').forEach((button) => {
    button.addEventListener('click', () => {
      const date = button.dataset.date;
      const input = document.getElementById('seminarDateInput');
      const text = document.getElementById('selectedDateText');
      if (!input || !text) return;
      input.value = date;
      const parts = date.split('-');
      text.textContent = `${parts[2]}.${parts[1]}.${parts[0]}`;
      document.querySelectorAll('.calendar-day').forEach((day) => day.classList.remove('selected'));
      button.classList.add('selected');
      openSeminarModal();
      setTimeout(() => { document.getElementById('seminarDateInput')?.focus({ preventScroll: true }); }, 150);
    });
  });

  seminarModalClose?.addEventListener('click', closeSeminarModal);
  seminarModal?.addEventListener('click', (event) => { if (event.target === seminarModal) closeSeminarModal(); });
  document.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeSeminarModal(); });
  if (seminarModal?.classList.contains('open')) document.body.classList.add('modal-open');

  const saveSuccessModal = document.getElementById('saveSuccessModal');
  const saveSuccessDate = document.getElementById('saveSuccessDate');
  const successAnotherDay = document.getElementById('successAnotherDay');

  function openSaveSuccessModal(dateText) {
    if (saveSuccessDate && dateText) saveSuccessDate.textContent = dateText;
    if (!saveSuccessModal) return;
    closeSeminarModal();
    saveSuccessModal.classList.add('open');
    saveSuccessModal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('modal-open');
  }

  function closeSaveSuccessModal() {
    if (!saveSuccessModal) return;
    saveSuccessModal.classList.remove('open');
    saveSuccessModal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
  }

  successAnotherDay?.addEventListener('click', () => {
    closeSaveSuccessModal();
    document.getElementById('calendar-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  if (saveSuccessModal?.classList.contains('open')) {
    document.body.classList.add('modal-open');
  }

  document.getElementById('seminarForm')?.addEventListener('submit', async (event) => {
    const form = event.currentTarget;
    const input = document.getElementById('seminarDateInput');
    if (!input || !input.value) {
      event.preventDefault();
      alert('Selectează mai întâi ziua seminarului din calendar.');
      return;
    }

    if (!form.dataset.ajaxSave) return;
    event.preventDefault();

    const submitButton = form.querySelector('button[type="submit"]');
    if (submitButton?.disabled) return;
    const originalText = submitButton ? submitButton.textContent : '';

    const startInput = form.querySelector('[name="startTime"]');
    const endInput = form.querySelector('[name="endTime"]');
    form.querySelectorAll('.field-error').forEach((el) => el.classList.remove('field-error'));

    if (!startInput?.value || !endInput?.value) {
      event.preventDefault();
      [startInput, endInput].forEach((el) => { if (el && !el.value.trim()) el.classList.add('field-error'); });
      alert('Completează ora de început și ora finală.');
      return;
    }

    if (startInput.value && endInput.value && endInput.value <= startInput.value) {
      event.preventDefault();
      endInput.classList.add('field-error');
      alert('Ora finală trebuie să fie după ora de început.');
      return;
    }

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Se salvează...';
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: new URLSearchParams(new FormData(form)),
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) throw new Error(result.message || 'Nu am putut salva seminarul.');

      const dateKey = result.date || input.value;
      const savedButton = document.querySelector(`.js-pick-day[data-date="${dateKey}"]`);
      if (savedButton && result.seminarId) {
        const link = document.createElement('a');
        link.className = 'calendar-day saved';
        link.dataset.date = dateKey;
        link.href = `/trainer/reports/${form.dataset.reportId}?month=${form.dataset.selectedMonth}&seminar=${result.seminarId}#calendar-section`;
        link.title = 'Vezi detalii seminar';
        const day = Number(dateKey.slice(-2));
        const start = form.querySelector('[name="startTime"]')?.value || 'salvat';
        const end = form.querySelector('[name="endTime"]')?.value || '';
        link.innerHTML = `<strong>${day}</strong><span>${start}${end ? ' - ' + end : ''}</span>`;
        savedButton.replaceWith(link);
      }

      form.reset();
      form.querySelectorAll('[data-multi-select]').forEach(refreshMultiSelectSummary);
      openSaveSuccessModal(result.savedDateDisplay || 'selectată');
    } catch (error) {
      alert(error.message || 'A apărut o eroare la salvare.');
    } finally {
      if (submitButton) {
        submitButton.disabled = false;
        submitButton.textContent = originalText;
      }
    }
  });

  const seminarDeleteModal = document.getElementById('seminarDeleteModal');
  const seminarDeleteText = document.getElementById('seminarDeleteText');
  const seminarDeleteCancel = document.getElementById('seminarDeleteCancel');
  const seminarDeleteConfirm = document.getElementById('seminarDeleteConfirm');
  let pendingSeminarDelete = null;

  document.querySelectorAll('.js-delete-seminar').forEach((button) => {
    button.addEventListener('click', () => {
      pendingSeminarDelete = button;
      if (seminarDeleteText) seminarDeleteText.textContent = `Sigur vrei să ștergi seminarul din ${button.dataset.date}? Această acțiune nu poate fi anulată.`;
      seminarDeleteModal?.classList.add('open');
      seminarDeleteModal?.setAttribute('aria-hidden', 'false');
      document.body.classList.add('modal-open');
    });
  });

  function closeSeminarDeleteModal() {
    seminarDeleteModal?.classList.remove('open');
    seminarDeleteModal?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('modal-open');
    pendingSeminarDelete = null;
  }

  seminarDeleteCancel?.addEventListener('click', closeSeminarDeleteModal);
  seminarDeleteModal?.addEventListener('click', (event) => { if (event.target === seminarDeleteModal) closeSeminarDeleteModal(); });
  seminarDeleteConfirm?.addEventListener('click', async () => {
    if (!pendingSeminarDelete) return;
    seminarDeleteConfirm.disabled = true;
    const original = seminarDeleteConfirm.textContent;
    seminarDeleteConfirm.textContent = 'Se șterge...';
    try {
      const response = await fetch(pendingSeminarDelete.dataset.deleteUrl, {
        method: 'POST',
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) throw new Error(result.message || 'Nu am putut șterge seminarul.');
      window.location.href = `/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>#calendar-section`;
    } catch (error) {
      alert(error.message || 'A apărut o eroare la ștergere.');
    } finally {
      seminarDeleteConfirm.disabled = false;
      seminarDeleteConfirm.textContent = original;
    }
  });

  const calendarSection = document.getElementById('calendar-section');
  if (calendarSection && window.location.hash === '#calendar-section') {
    setTimeout(() => {
      calendarSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      calendarSection.focus({ preventScroll: true });
    }, 120);
  }
</script>

<%- include('../partials/footer') %>
