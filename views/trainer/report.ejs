<%- include('../partials/header') %>

<style>
/* UI mai compact */
.calendar-day {
  min-height: 58px;
  border-radius: 13px;
  padding: 8px;
}

.calendar-day strong {
  font-size: 15px;
}

.calendar-day span {
  font-size: 10px;
}

.seminar-calendar {
  gap: 6px;
}

.calendar-head {
  font-size: 10px;
}

.trainee-panel {
  max-width: 240px;
}

.trainee-list span {
  font-size: 13px;
  padding: 8px 10px;
}

.seminar-form input,
.seminar-form textarea,
.seminar-form select {
  font-size: 14px;
}
</style>

<div class="back-row">
  <a class="btn ghost" href="/trainer">← Înapoi</a>
</div>

<section class="report-hero compact-course-hero">
  <div>
    <h1><%= report.title %></h1>
    <p><%= report.location %></p>
  </div>
</section>

<% if (selectedMonth) { %>
<%
  const [calendarYear, calendarMonth] = selectedMonth.split('-').map(Number);
  const daysInMonth = new Date(calendarYear, calendarMonth, 0).getDate();

  const seminarsByDate = {};
  seminarsInMonth.forEach(s => {
    seminarsByDate[dateInputValue(s.date)] = s;
  });

  const selectedDateKey = selectedSeminar ? dateInputValue(selectedSeminar.date) : '';
%>

<section class="trainer-layout">

  <!-- LISTA CURSANTI -->
  <aside class="trainee-panel">
    <div class="sticky-card">
      <h2>Lista cursanți</h2>
      <div class="trainee-list">
        <% report.trainees.forEach((t, index) => { %>
          <span><b><%= index + 1 %>.</b> <%= t.name %></span>
        <% }) %>
      </div>
    </div>
  </aside>

  <!-- CALENDAR -->
  <div class="report-panel">
    <section class="card history-card">
      <h2>Calendar</h2>

      <div class="seminar-calendar">
        <% for (let day = 1; day <= daysInMonth; day++) { %>
          <%
            const dateKey = `${calendarYear}-${String(calendarMonth).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
            const saved = seminarsByDate[dateKey];
          %>

          <% if (saved) { %>
            <a class="calendar-day saved"
               href="/trainer/reports/<%= report._id %>?month=<%= selectedMonth %>&seminar=<%= saved._id %>">
              <strong><%= day %></strong>
              <span>✔</span>
            </a>
          <% } else { %>
            <button class="calendar-day js-pick-day"
                    data-date="<%= dateKey %>">
              <strong><%= day %></strong>
              <span>Adaugă</span>
            </button>
          <% } %>
        <% } %>
      </div>
    </section>

    <!-- FORMULAR -->
    <form action="/trainer/reports/<%= report._id %>/seminars" method="post" class="card seminar-form" id="seminarForm">
      <input type="hidden" name="selectedMonth" value="<%= selectedMonth %>">

      <h2>Adaugă zi de curs</h2>

      <div>
        Zi selectată:
        <b id="selectedDateText">
          <%= selectedSeminar ? new Date(selectedSeminar.date).toLocaleDateString('ro-RO') : 'alege zi' %>
        </b>
      </div>

      <!-- DATA FIX -->
      <label>Data
        <input id="seminarDateDisplay" type="text" readonly>
        <input id="seminarDateInput" name="date" type="hidden" required>
      </label>

      <!-- ORE 24H -->
      <label>Ora început
        <input name="startTime" type="time" step="60" lang="ro-RO">
      </label>

      <label>Ora final
        <input name="endTime" type="time" step="60" lang="ro-RO">
      </label>

      <label>Activitate
        <textarea name="activity"></textarea>
      </label>

      <button class="btn primary">Salvează</button>
    </form>

  </div>
</section>
<% } %>

<script>
// selectare zi
document.querySelectorAll('.js-pick-day').forEach(btn => {
  btn.addEventListener('click', () => {
    const date = btn.dataset.date;

    const input = document.getElementById('seminarDateInput');
    const display = document.getElementById('seminarDateDisplay');
    const text = document.getElementById('selectedDateText');

    input.value = date;

    const parts = date.split('-');
    const ro = `${parts[2]}/${parts[1]}/${parts[0]}`;

    display.value = ro;
    text.textContent = ro;

    document.querySelectorAll('.calendar-day').forEach(d => d.classList.remove('selected'));
    btn.classList.add('selected');
  });
});

// validare
document.getElementById('seminarForm').addEventListener('submit', e => {
  if (!document.getElementById('seminarDateInput').value) {
    e.preventDefault();
    alert('Selectează ziua din calendar!');
  }
});
</script>

<%- include('../partials/footer') %>
